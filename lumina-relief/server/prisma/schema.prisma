generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  contact             String
  password            String
  auditLogs           AuditLog[]
  locationAssignments LocationAssignment[]

  @@map("users")
}

model Location {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  status              Status
  barangay            String
  city                String
  country             String
  province            String
  region              String
  zipCode             String
  latitude            Float
  longitude           Float
  inventories         Inventory[]
  locationAssignments LocationAssignment[]
  locationContacts    LocationContact[]

  @@map("locations")
}

model LocationAssignment {
  id         Int      @id @default(autoincrement())
  locationId Int      @map("location_id")
  userId     Int      @map("user_id")
  location   Location @relation(fields: [locationId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([locationId, userId])
  @@map("location_assignments")
}

model Contact {
  id               Int               @id @default(autoincrement())
  contactInfo      String            @unique @map("contact_info")
  contactType      String            @map("contact_type")
  locationContacts LocationContact[]

  @@map("contacts")
}

model LocationContact {
  id         Int      @id @default(autoincrement())
  locationId Int      @map("location_id")
  contactId  Int      @map("contact_id")
  contact    Contact  @relation(fields: [contactId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, contactId])
  @@map("location_contacts")
}

model Resource {
  id          Int         @id @default(autoincrement())
  category    String
  name        String
  unit        String
  inventories Inventory[]

  @@map("resources")
}

model Inventory {
  id          Int         @id @default(autoincrement())
  quantity    Int
  stockLevel  StockStatus @map("stock_level")
  lastUpdated DateTime    @updatedAt @map("last_updated")
  locationId  Int         @map("location_id")
  resourceId  Int         @map("resource_id")
  auditLogs   AuditLog[]
  location    Location    @relation(fields: [locationId], references: [id])
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@map("inventories")
}

model AuditLog {
  id           Int       @id @default(autoincrement())
  inventoryId  Int       @map("inventory_id")
  userId       Int       @map("user_id")
  prevQuantity Int       @map("prev_quantity")
  newQuantity  Int       @map("new_quantity")
  timeChanged  DateTime  @default(now()) @map("time_changed")
  inventory    Inventory @relation(fields: [inventoryId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum Status {
  ACTIVE
  INACTIVE
  FULL
}

enum StockStatus {
  OUT_OF_STOCK
  LOW_STOCK
  IN_STOCK
  OVERSTOCKED

  @@map("stock_status")
}
